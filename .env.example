# ═══════════════════════════════════════════════════════════
# AETHER STOREFRONT - ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# Database & Server
MONGODB_URI=mongodb://localhost:27017/ecommerce
PORT=5000
NODE_ENV=development

# 📧 EMAIL CONFIGURATION (SMTP)
# Recommended: Brevo, SendGrid, or Mailtrap
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_login
EMAIL_PASS=your_smtp_key

# IMPORTANT: EMAIL_FROM must be a VERIFIED SENDER in your SMTP dashboard
EMAIL_FROM="AETHER Store" <no-reply@yourdomain.com>
